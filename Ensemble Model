# ==== CONFIG ====
MODEL_NAME = "distilbert-base-uncased"
MAX_LEN = 128
BATCH_SIZE = 32
EPOCHS = 50
LR = 2e-5
WEIGHT_DECAY = 0.01
DROPOUT = 0.2
SEED = 42
FOCAL_ALPHA = 0.75 # Adjusted alpha for imbalanced dataset
FOCAL_GAMMA = 2.0
GRAD_CLIP = 1.0
EARLY_STOP_PATIENCE = 3
LR_DECAY_STEP = 2 # Step size for learning rate decay
LR_DECAY_GAMMA = 0.5 # Decay rate for learning rate
N_BOOTSTRAPS = 1000 # Number of bootstraps for CI calculation
