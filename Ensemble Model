# ==== BOOTSTRAPPING FOR CONFIDENCE INTERVALS ====
def bootstrap_confidence_intervals(y_true, y_pred_raw, n_bootstraps=N_BOOTSTRAPS, alpha=CONF_ALPHA):
    bootstrapped_roc_aucs = []
    bootstrapped_prc_aucs = []
    bootstrapped_f1_scores = []
    bootstrapped_accuracies = []
    bootstrapped_precisions = [] # for positive class
    bootstrapped_recalls = []    # for positive class


    # For curves
    tprs_list = []
    precisions_list = []
    # Use a common set of points for interpolation to combine curves
    mean_fpr = np.linspace(0, 1, 100)
    mean_recall_for_interp = np.linspace(0, 1, 100) # For PR curve interpolation


    for i in range(n_bootstraps):
        # Resample with replacement
        indices = resample(np.arange(len(y_true)), replace=True, n_samples=len(y_true), random_state=i)
        y_true_resampled = y_true[indices]
        y_pred_raw_resampled = y_pred_raw[indices]


        # Calculate ROC metrics
        fpr, tpr, _ = roc_curve(y_true_resampled, y_pred_raw_resampled)
        roc_auc = auc(fpr, tpr)
        bootstrapped_roc_aucs.append(roc_auc)


        # Interpolate TPRs to a common FPR grid for CI calculation
        interp_tpr = interp1d(fpr, tpr, kind='linear', fill_value=(tpr[0], tpr[-1]), bounds_error=False)(mean_fpr)
        tprs_list.append(interp_tpr)


        # Calculate PR metrics
        precision, recall, _ = precision_recall_curve(y_true_resampled, y_pred_raw_resampled)
        prc_auc = average_precision_score(y_true_resampled, y_pred_raw_resampled)
        bootstrapped_prc_aucs.append(prc_auc)


        # Interpolate Precisions to a common Recall grid for CI calculation (reverse order for interpolation)
        # Note: PR curves typically start high precision/low recall and move to low precision/high recall
        # Interpolate based on sorted recall values
        sorted_recall_indices = np.argsort(recall)
        interp_precision = interp1d(recall[sorted_recall_indices], precision[sorted_recall_indices], kind='linear', fill_value=(precision[sorted_recall_indices[0]], precision[sorted_recall_indices[-1]]), bounds_error=False)(mean_recall_for_interp)
        precisions_list.append(interp_precision)


        # Calculate binary classification metrics
        y_pred_resampled = (torch.sigmoid(torch.tensor(y_pred_raw_resampled)) > 0.5).int().numpy()
        bootstrapped_f1_scores.append(f1_score(y_true_resampled, y_pred_resampled, zero_division=0))
        bootstrapped_accuracies.append(accuracy_score(y_true_resampled, y_pred_resampled))
        bootstrapped_precisions.append(precision_score(y_true_resampled, y_pred_resampled, zero_division=0))
        bootstrapped_recalls.append(recall_score(y_true_resampled, y_pred_resampled, zero_division=0))


    # Calculate CIs for metrics
    lower_percentile = (1 - alpha) / 2 * 100
    upper_percentile = (1 + alpha) / 2 * 100


    roc_auc_ci = np.percentile(bootstrapped_roc_aucs, [lower_percentile, upper_percentile])
    prc_auc_ci = np.percentile(bootstrapped_prc_aucs, [lower_percentile, upper_percentile])
    f1_ci = np.percentile(bootstrapped_f1_scores, [lower_percentile, upper_percentile])
    accuracy_ci = np.percentile(bootstrapped_accuracies, [lower_percentile, upper_percentile])
    precision_pos_ci = np.percentile(bootstrapped_precisions, [lower_percentile, upper_percentile])
    recall_pos_ci = np.percentile(bootstrapped_recalls, [lower_percentile, upper_percentile])


    # Calculate CIs for curves
    tprs_lower = np.percentile(tprs_list, lower_percentile, axis=0)
    tprs_upper = np.percentile(tprs_list, upper_percentile, axis=0)


    precisions_lower = np.percentile(precisions_list, lower_percentile, axis=0)
    precisions_upper = np.percentile(precisions_list, upper_percentile, axis=0)


    return {
        'roc_auc_ci': roc_auc_ci,
        'prc_auc_ci': prc_auc_ci,
        'f1_ci': f1_ci,
        'accuracy_ci': accuracy_ci,
        'precision_pos_ci': precision_pos_ci,
        'recall_pos_ci': recall_pos_ci,
        'mean_fpr': mean_fpr,
        'tprs_lower': tprs_lower,
        'tprs_upper': tprs_upper,
        'mean_recall_for_interp': mean_recall_for_interp,
        'precisions_lower': precisions_lower,
        'precisions_upper': precisions_upper,
    }




