# Define a prediction function for SHAP
def predict_proba_shap(texts):
    model.eval()


    encoded_input = base_tokenizer(
        texts.tolist() if isinstance(texts, np.ndarray) else texts,
        padding='max_length',
        truncation=True,
        max_length=MAX_LEN,
        return_tensors='pt'
    )


    input_ids = encoded_input['input_ids'].to(device)
    attention_mask = encoded_input['attention_mask'].to(device)


    with torch.no_grad():
        logits = model(input_ids, attention_mask)
        probabilities = torch.sigmoid(logits).cpu().numpy()


    # Single-output model → return probability of positive class
    return probabilities.flatten()




num_shap_samples = 50


sampled_test_df_for_shap = test_df[test_df['proc_seq'].apply(lambda x: len(x) > 0)]
