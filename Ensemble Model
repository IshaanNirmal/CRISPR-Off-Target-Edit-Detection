)


print(f"Train size: {len(train_df)}, Val size: {len(val_df)}, Test size: {len(test_df)})")


# ==== BUILD CONCATENATED SEQUENCES ====
def build_input(row):
    return f"{row['sgRNA_seq']} | {row['off_seq']}"


train_df['input_seq'] = train_df.apply(build_input, axis=1)
