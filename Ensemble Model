random.seed(SEED)


# ==== TOKENIZER (char-level trick for RNA) ====
base_tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)


def char_space(seq):
    # replace T with U and add spaces between characters
    return " ".join(list(seq.replace("T", "U")))


# ==== DATA SPLIT ====
# Use df_no_guide_seq for training and validation, and df_guide_seq for testing
trainval_df = df_no_guide_sampled.copy()
test_df = df_guide_sampled.copy()


# Split train/val (90%/10% of trainval_df)
train_df, val_df = train_test_split(
